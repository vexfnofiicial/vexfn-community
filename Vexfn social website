<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>VexFN Community</title>
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
  <style>
    body {
      margin: 0;
      font-family: Inter, sans-serif;
      background: #0B0F1A;
      color: #E5E7EB;
    }

    header {
      padding: 40px;
      text-align: center;
      background: linear-gradient(90deg, #7C3AED, #22D3EE);
    }

    header h1 {
      font-family: Orbitron, sans-serif;
      font-size: 40px;
      margin: 0;
    }

    nav {
      display: flex;
      justify-content: center;
      gap: 20px;
      padding: 15px;
      background: #121A2A;
    }

    nav a {
      color: #E5E7EB;
      text-decoration: none;
      font-weight: 600;
    }

    section {
      padding: 60px 20px;
      max-width: 1000px;
      margin: auto;
    }

    .card {
      background: #121A2A;
      padding: 20px;
      border-radius: 12px;
      margin-top: 20px;
    }

    .glow {
      color: #22D3EE;
    }

    footer {
      text-align: center;
      padding: 30px;
      background: #121A2A;
      margin-top: 40px;
      font-size: 14px;
    }

    .players {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 15px;
    }

    .player {
      background: #0F172A;
      padding: 15px;
      border-radius: 10px;
      border: 1px solid #1F2937;
    }
  </style>
</head>
<body>

<header>
  <h1>VexFN Community</h1>
  <p>Competitive Fortnite Community</p>
</header>

<nav>
  <a href="#home">Home</a>
  <a href="#about">About</a>
  <a href="#achievements">Achievements</a>
  <a href="#players">Players</a>
</nav>

<section id="home">
  <h2>Welcome</h2>
  <div class="card">
    Made by <span class="glow">TaylorFG</span><br>
    Join our Discord to become part of the VexFN Community.
  </div>
</section>

<section id="about">
  <h2>About Us</h2>
  <div class="card">
    VexFN is a Fortnite-focused competitive community built for players who want to improve, compete, and join events.
  </div>
</section>

<section id="achievements">
  <h2>Achievements</h2>
  <div class="card">
    🏆 VexFN Cup Winner (EU Server)
    <br>
    🏆 VexFN Cup Winner (United States Server)
    <br>
    🏆 Multiple Community Tournament Wins
  </div>
</section>

<section id="players">
  <h2>VexFN Players</h2>
  <div class="players">
    <div class="player">VexNova</div>
    <div class="player">FG_Taylor</div>
    <div class="player">ShadowVex</div>
    <div class="player">ClutchRex</div>
    <div class="player">PixelFG</div>
    <div class="player">StormVex</div>
  </div>
</section>

<footer>
  © VexFN Community | Made by TaylorFG | All rights reserved
</footer>

</body>
</html>
